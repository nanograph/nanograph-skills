# Copy this to .env.nano before running nanograph commands that embed or query text:
#   cp .env.nano.example .env.nano
#
# nanograph auto-loads .env.nano from the current working directory.
# Only one of OPENAI_API_KEY or GEMINI_API_KEY is needed, matching [embedding].provider in nanograph.toml.
# Use Gemini if you want multimodal (image/audio/video/PDF) embedding.

OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
